
# OTEL javaagent — fetched at deploy time by ansible (otel/download-agent.sh)
local-setup/otel/opentelemetry-javaagent.jar

# Python bytecode + caches
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/

# Per-tenant Ansible host_vars — real values are sensitive (OpenBao
# bootstrap secrets, ansible_host, etc.). The committed template is
# inventory/host_vars/_example.yml; everything else is per-operator.
local-setup/ansible/inventory/host_vars/*.yml
!local-setup/ansible/inventory/host_vars/_example.yml

# Auto-generated by deploy.sh on each run from host_vars/*.yml.
# Reference template is inventory/hosts.yml.example.
local-setup/ansible/inventory/hosts.yml

# Project-local Claude notes — uncommitted operator's reference.
CLAUDE.md
