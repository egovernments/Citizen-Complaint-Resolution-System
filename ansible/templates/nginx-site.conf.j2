# Generated by ansible from inventory/host_vars/{{ inventory_hostname }}.yml
# + group_vars/digit.yml. Edit the inventory, not this file.
#
# Each `location` block below is conditional on a flag in the inventory's
# `nginx_features` map — flip the flag rather than commenting locations
# out by hand. SSL termination + http→https redirect are managed by
# Certbot (the `# managed by Certbot` blocks below).
server {
  server_name {{ domain }};

{% if nginx_features.brand_assets %}
  # Brand assets (logos, footers) served from /var/www/brand/. Requires
  # the host to have brand assets pre-seeded under that path.
  location /brand/ {
    alias /var/www/brand/;
    add_header Cache-Control "public, max-age=31536000, immutable" always;
    try_files $uri =404;
  }

{% endif %}
{% if nginx_features.configurator %}
{% if nginx_features.configurator_caching %}
  # Configurator SPA — long-cache the hashed assets/, no-cache index.
  location /configurator/assets/ {
    alias /var/www/configurator/assets/;
    add_header Cache-Control "public, max-age=31536000, immutable" always;
    try_files $uri =404;
  }

  location /configurator {
    alias /var/www/configurator/;
    try_files $uri $uri/ /configurator/index.html;
    add_header Cache-Control "no-cache, must-revalidate" always;
  }
{% else %}
  # Configurator SPA (no asset-level caching).
  location /configurator {
    alias /var/www/configurator/;
    try_files $uri $uri/ /configurator/index.html;
  }
{% endif %}

{% endif %}
  # Grafana dashboard
  location /grafana/ {
    proxy_pass http://127.0.0.1:{{ upstream_grafana_port }};
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_http_version 1.1;
    proxy_set_header Upgrade $http_upgrade;
    proxy_set_header Connection "upgrade";
  }

{% if nginx_features.status %}
  # Gatus health page — public path /status/, SPA assets rewritten on the fly.
  # Gatus's index.html / JS reference assets and the API as absolute paths
  # from root. We sub_filter every layer so the browser routes everything
  # through this /status/ proxy (which strips the prefix back off).
  location /status/ {
    proxy_pass http://127.0.0.1:{{ upstream_gatus_port }}/;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;

    # sub_filter can't rewrite gzipped bodies — force identity.
    proxy_set_header Accept-Encoding "";
    sub_filter_once off;
    sub_filter_types text/html application/javascript text/javascript application/json;
    sub_filter 'src="/js/'        'src="/status/js/';
    sub_filter 'href="/css/'      'href="/status/css/';
    sub_filter 'href="/favicon'   'href="/status/favicon';
    sub_filter 'href="/apple-touch-icon' 'href="/status/apple-touch-icon';
    sub_filter 'href="/manifest.json' 'href="/status/manifest.json';
    sub_filter '"/api/v1/'        '"/status/api/v1/';
    sub_filter "'/api/v1/"        "'/status/api/v1/";
    sub_filter 's.p="/"'      's.p="/status/"';
    sub_filter '("/"),routes:' '("/status/"),routes:';
    sub_filter "`/api/v1/"        "`/status/api/v1/";
  }

  # Backwards-compat: the old /gatus/ path 301s to /status/.
  location = /gatus {
    return 301 $scheme://$host/status/;
  }

{% endif %}
{% if nginx_features.api_pgr %}
  # PGR Dashboard API (proxied to MCP server)
  location /api/pgr/ {
    proxy_pass http://127.0.0.1:{{ upstream_mcp_port }};
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
  }

{% endif %}
{% if nginx_features.mcp %}
  # DIGIT MCP server (HTTP transport at /mcp; healthcheck at /mcp/healthz).
  # Streaming-friendly: long timeouts and buffering disabled for SSE.
  # WARNING: this exposes admin tools (mdms_create, user_create,
  # employee_create, tenant_bootstrap, pgr_update, …) without auth.
  # Only safe for test deployments.
  location /mcp {
    proxy_pass http://127.0.0.1:{{ upstream_mcp_port }};
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_http_version 1.1;
    proxy_set_header Connection "";
    proxy_buffering off;
    proxy_read_timeout 24h;
    proxy_send_timeout 24h;
  }

{% endif %}
{% if digit_ui_mode == "static" %}
  # digit-ui in static mode: host nginx serves the build artifact from
  # /opt/digit-ui-esbuild/build/ directly. Built by the playbook
  # (`node esbuild.build.js`) — no inner Docker container, no esbuild
  # dev server. Faster, fewer moving parts, smaller blast radius.
  location = /digit-ui {
    return 302 /digit-ui/;
  }
  location /digit-ui/ {
    alias /opt/digit-ui-esbuild/build/;
    try_files $uri $uri/ /digit-ui/index.html;
    sub_filter_once on;
    sub_filter_types text/html;
    sub_filter '</head>' '<script src="/digit-ui/globalConfigs.js"></script></head>';
  }
  # Per-tenant boot config — overrides whatever was baked into the bundle.
  location = /digit-ui/globalConfigs.js {
    alias {{ digit_dir }}/nginx/globalConfigs.js;
    default_type application/javascript;
    add_header Cache-Control "no-cache, must-revalidate" always;
  }
  # API calls go to Kong directly.
  location / {
    proxy_pass http://127.0.0.1:{{ upstream_kong_port }};
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_read_timeout 120s;
    proxy_buffering off;
  }
{% else %}
  # digit-ui in HMR mode: esbuild dev server (tmux session) on :18080.
  # Serves both /digit-ui/* (the SPA) and proxies API calls to Kong.
  # Live reloads on file save in /opt/digit-ui-esbuild.
  location / {
    proxy_pass http://127.0.0.1:{{ upstream_esbuild_port }};
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_read_timeout 120s;
    proxy_buffering off;
  }
{% endif %}

{% if tls_enabled | default(true) %}
    # Certbot-managed TLS. Set `tls_enabled: false` in host_vars/<tenant>.yml
    # for boxes without a Let's Encrypt cert (e.g. iteration sandboxes).
    listen 443 ssl; # managed by Certbot
    ssl_certificate /etc/letsencrypt/live/{{ domain }}/fullchain.pem; # managed by Certbot
    ssl_certificate_key /etc/letsencrypt/live/{{ domain }}/privkey.pem; # managed by Certbot
    include /etc/letsencrypt/options-ssl-nginx.conf; # managed by Certbot
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem; # managed by Certbot
{% else %}
    # tls_enabled=false — listen on plain HTTP only (sandbox / no Let's Encrypt cert).
    listen 80;
{% endif %}

}
{% if tls_enabled | default(true) %}
server {
    # HTTP→HTTPS redirect (only meaningful when TLS is on).
    if ($host = {{ domain }}) {
        return 301 https://$host$request_uri;
    } # managed by Certbot


  listen 80;
  server_name {{ domain }};
    return 404; # managed by Certbot


}
{% endif %}
