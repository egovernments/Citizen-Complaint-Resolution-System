SKIP_PREFLIGHT_CHECK=true

# Local CRA dev: cp public/globalConfigs.example.js public/globalConfigs.js

REACT_APP_STATE_LEVEL_TENANT_ID=pb
REACT_APP_PROXY_URL=https://works-dev.digit.org

# Supervisor dashboard — analytics API (browser path or full URL)
# Dev default: /pgr-analytics (proxied by setupProxy.js)
# Prod default: /api/analytics (same origin as the UI)
# REACT_APP_ANALYTICS_BASE=/pgr-analytics

# Dev server only — where /pgr-analytics is proxied (see setupProxy.js)
# Default: http://127.0.0.1:18280 → /pgr-services/v2/analytics (SSH tunnel)
# ANALYTICS_PROXY_URL=http://127.0.0.1:18280
# ANALYTICS_BASIC_USER=
# ANALYTICS_BASIC_PASSWORD=
