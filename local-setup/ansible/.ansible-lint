---
# ansible-lint configuration for DIGIT local-setup playbook.
# Profile "basic" catches real bugs; style-only rules are skipped below.
profile: basic

# Auto-generated or vendored files — don't lint these.
exclude_paths:
  - inventory/hosts.yml        # regenerated by deploy.sh on every run
  - nairobi-mdms/              # external submodule

skip_list:
  # ── Style rules: require touching every task; provide no safety value ──
  - fqcn[action-core]          # short module names (apt, shell, copy) are fine
  - name[casing]               # task names don't need to start with uppercase
  - yaml[truthy]               # yes/no are valid booleans in Ansible
  - yaml[line-length]          # handled by .yamllint with a relaxed 160-char limit
  - yaml[colons]               # intentional alignment in build-context maps
  - yaml[braces]               # inline loop maps use { key: val } style intentionally
  - jinja[spacing]             # cosmetic Jinja2 pipe spacing

  # ── Design-level rules: inherent to this playbook's architecture ──
  - complexity                 # single large play is intentional; splitting is out of scope
  - name[template]            # task names contain {{ inventory_hostname }} for clarity
  - risky-file-permissions     # compose/config copies where mode is intentionally omitted
  - command-instead-of-shell   # shell used intentionally in many places
  - command-instead-of-module  # shell over module is a deliberate choice in some tasks

# Rules below are ENFORCED (not in skip_list):
#   risky-shell-pipe  — pipes must have set -o pipefail
#   no-changed-when   — shell/command tasks must declare changed_when
#   ignore-errors     — use failed_when instead of ignore_errors
#   literal-compare   — don't compare to literal True/False
