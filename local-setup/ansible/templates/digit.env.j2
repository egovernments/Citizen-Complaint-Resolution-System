# Per-tenant Docker Compose .env — auto-loaded from the working directory.
# Generated by ansible from inventory/host_vars/{{ inventory_hostname }}.yml.
# Edit the inventory, not this file.
GF_SERVER_DOMAIN={{ domain }}
GF_SERVER_ROOT_URL=https://{{ domain }}/grafana/

# Custom Docker registry — drives the MCP image pull. Override in
# host_vars by setting `docker_registry: <your-registry-host:port>`.
MCP_IMAGE={{ docker_registry }}/digit-mcp:latest
