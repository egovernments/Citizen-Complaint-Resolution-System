# Per-tenant Docker Compose .env — auto-loaded from the working directory.
# Generated by ansible from inventory/host_vars/{{ inventory_hostname }}.yml.
# Edit the inventory, not this file.
GF_SERVER_DOMAIN={{ domain }}
GF_SERVER_ROOT_URL=https://{{ domain }}/grafana/

# MCP image. Resolved by the "Resolve MCP image tag" task: a local-only
# tag (digit-mcp:local) when build_mcp:true (deploy builds it itself, no
# registry), else {{ docker_registry }}/digit-mcp:latest. Override with
# `mcp_image:` in host_vars.
MCP_IMAGE={{ mcp_image }}

# default-data-handler image. Same pattern as MCP_IMAGE: a local tag
# (default-data-handler:local) when build_default_data_handler:true
# (deploy builds it from utilities/default-data-handler), else the
# pinned {{ docker_registry }}/default-data-handler:<sha> ref.
# Override with `ddh_image:` in host_vars.
DDH_IMAGE={{ ddh_image }}

# JVM flags appended to every service's JAVA_TOOL_OPTIONS, gated on target OS.
# Darwin (Apple-Silicon Mac under Rosetta amd64): the C2 JIT compiler SIGBUSes
# (CompileBroker::collect_statistics) and CDS mmap'd archives also SIGBUS — so
# force C1-only JIT + disable CDS. Linux targets get an empty string -> zero
# production impact (Bomet / naipepea unaffected).
MAC_JVM_OPTS={{ '-XX:TieredStopAtLevel=1 -Xshare:off' if ansible_system == 'Darwin' else '' }}

{% if enable_novu | default(false) %}
# Novu dashboard SPA runs in the operator's browser — it can't reach
# `localhost:14002` because that would mean the operator's laptop.
# Use the rendered domain, proxied through the host nginx /novu-api/
# and /novu-ws/ locations (defined in nginx-site.conf.j2 under the
# same enable_novu flag). Single-origin keeps cookies / CORS clean.
NOVU_NODE_ENV=production
NOVU_API_PUBLIC_URL={{ 'https://' + domain if (tls_enabled | default(true)) else 'http://' + domain }}/novu-api
NOVU_WS_PUBLIC_URL={{ 'https://' + domain if (tls_enabled | default(true)) else 'http://' + domain }}/novu-ws
NOVU_API_ROOT_URL={{ 'https://' + domain if (tls_enabled | default(true)) else 'http://' + domain }}/novu-api
NOVU_FRONT_BASE_URL={{ 'https://' + domain if (tls_enabled | default(true)) else 'http://' + domain }}/novu
{% endif %}
