# Generated by ansible from inventory/host_vars/{{ inventory_hostname }}.yml
# + group_vars/digit.yml. Edit the inventory, not this file.
#
# Each `location` block below is conditional on a flag in the inventory's
# `nginx_features` map — flip the flag rather than commenting locations
# out by hand. SSL termination + http→https redirect are managed by
# Certbot (the `# managed by Certbot` blocks below).
server {
  server_name {{ domain }};

{% if nginx_features.brand_assets %}
  # Brand assets (logos, footers) served from /var/www/brand/. Requires
  # the host to have brand assets pre-seeded under that path.
  location /brand/ {
    alias /var/www/brand/;
    add_header Cache-Control "public, max-age=31536000, immutable" always;
    try_files $uri =404;
  }

{% endif %}
{% if nginx_features.configurator %}
  # Redirect /configurator (no slash) → /configurator/ so the SPA loads
  # whether the user types the trailing slash or not. nginx's auto-slash
  # redirect doesn't fire for `location` blocks that use `alias`, so we
  # do it explicitly.
  location = /configurator { return 302 /configurator/; }

{% if nginx_features.configurator_caching %}
  # Configurator SPA — long-cache the hashed assets/, no-cache index.
  location /configurator/assets/ {
    alias /var/www/configurator/assets/;
    add_header Cache-Control "public, max-age=31536000, immutable" always;
    try_files $uri =404;
  }

  location /configurator/ {
    alias /var/www/configurator/;
    try_files $uri $uri/ /configurator/index.html;
    add_header Cache-Control "no-cache, must-revalidate" always;
  }
{% else %}
  # Configurator SPA (no asset-level caching).
  location /configurator/ {
    alias /var/www/configurator/;
    try_files $uri $uri/ /configurator/index.html;
  }
{% endif %}

{% endif %}
{% if nginx_features.digit_ui_v2 | default(false) %}
  # digit-ui-v2 — Vite + React 19 citizen SPA. Built from
  # {{ digit_ui_v2_branch | default('feat/digit-ui-v2-keycloak') }} on the
  # target ({{ digit_ui_v2_repo | default('digit-ui-v2 repo') }}) and
  # synced to /var/www/citizen/ by the ansible deploy. Hashed assets get
  # the long immutable cache; index.html stays no-cache so a redeploy
  # propagates without operators forcing a hard refresh.
  location /citizen/assets/ {
    alias /var/www/citizen/assets/;
    add_header Cache-Control "public, max-age=31536000, immutable" always;
    try_files $uri =404;
  }
  location /citizen {
    alias /var/www/citizen/;
    try_files $uri $uri/ /citizen/index.html;
    add_header Cache-Control "no-cache, must-revalidate" always;
  }

{% endif %}
{% if nginx_features.integration_tests | default(false) %}
  # digit-integration-tests dashboards — vanilla catalog SPA at
  # /tests/ and the react-admin rebuild at /tests-v2/ (matches naipepea's
  # route convention). Built from the vendored tests/integration-tests/ source
  # and synced to /var/www/integration-tests{,-v2}/ by the deploy. Behind
  # basic-auth (/etc/nginx/.htpasswd-tests, created by the playbook).
  # catalog.json + runs/ are produced out-of-band by a test runner, not the deploy.
  location = /tests    { return 301 /tests/; }
  location = /tests-v2 { return 301 /tests-v2/; }
  location /tests/ {
    alias /var/www/integration-tests/;
    auth_basic "DIGIT integration tests";
    auth_basic_user_file /etc/nginx/.htpasswd-tests;
    add_header Cache-Control "no-cache, must-revalidate" always;
    try_files $uri $uri/ $uri/index.html =404;
  }
  location /tests-v2/ {
    alias /var/www/integration-tests-v2/;
    auth_basic "DIGIT integration tests";
    auth_basic_user_file /etc/nginx/.htpasswd-tests;
    add_header Cache-Control "no-cache, must-revalidate" always;
    try_files $uri $uri/ /tests-v2/index.html =404;
  }
{% if nginx_features.integration_tests_runner | default(false) %}
  # RUN button → on-box test-runner daemon (loopback only; nginx is the auth).
  # SAME realm string as the dashboards above so the browser reuses the already-
  # entered basic-auth creds for the API calls. Longest-prefix match means this
  # wins over /tests/ for /tests/api/*. Long read-timeout
  # + buffering off so /run/<id>/log can stream a live console.
  location /tests/api/ {
    auth_basic "DIGIT integration tests";
    auth_basic_user_file /etc/nginx/.htpasswd-tests;
    proxy_pass http://127.0.0.1:{{ integration_tests_runner_port | default(8181) }}/;
    proxy_http_version 1.1;
    proxy_set_header Host $host;
    proxy_read_timeout 3600s;
    proxy_buffering off;
  }
{% endif %}

{% endif %}
  # Grafana dashboard
  location /grafana/ {
    proxy_pass http://{{ nginx_upstream_host | default('127.0.0.1') }}:{{ upstream_grafana_port }};
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_http_version 1.1;
    proxy_set_header Upgrade $http_upgrade;
    proxy_set_header Connection "upgrade";
  }

{% if nginx_features.status %}
  # Gatus health page — public path /status/, SPA assets rewritten on the fly.
  # Gatus's index.html / JS reference assets and the API as absolute paths
  # from root. We sub_filter every layer so the browser routes everything
  # through this /status/ proxy (which strips the prefix back off).
  location /status/ {
    proxy_pass http://{{ nginx_upstream_host | default('127.0.0.1') }}:{{ upstream_gatus_port }}/;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;

    # sub_filter can't rewrite gzipped bodies — force identity.
    proxy_set_header Accept-Encoding "";
    sub_filter_once off;
    sub_filter_types text/html application/javascript text/javascript application/json;
    sub_filter 'src="/js/'        'src="/status/js/';
    sub_filter 'href="/css/'      'href="/status/css/';
    sub_filter 'href="/favicon'   'href="/status/favicon';
    sub_filter 'href="/apple-touch-icon' 'href="/status/apple-touch-icon';
    sub_filter 'href="/manifest.json' 'href="/status/manifest.json';
    sub_filter '"/api/v1/'        '"/status/api/v1/';
    sub_filter "'/api/v1/"        "'/status/api/v1/";
    sub_filter 's.p="/"'      's.p="/status/"';
    sub_filter '("/"),routes:' '("/status/"),routes:';
    sub_filter "`/api/v1/"        "`/status/api/v1/";
  }

  # Backwards-compat: the old /gatus/ path 301s to /status/.
  location = /gatus {
    return 301 $scheme://$host/status/;
  }

{% endif %}
{% if nginx_features.api_pgr %}
  # PGR Dashboard API (proxied to MCP server)
  location /api/pgr/ {
    proxy_pass http://{{ nginx_upstream_host | default('127.0.0.1') }}:{{ upstream_mcp_port }};
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
  }

{% endif %}
{% if nginx_features.mcp %}
  # DIGIT MCP server (HTTP transport at /mcp; healthcheck at /mcp/healthz).
  # Streaming-friendly: long timeouts and buffering disabled for SSE.
  # WARNING: /mcp exposes admin tools (mdms_create, user_create,
  # employee_create, tenant_bootstrap, pgr_update, …) without auth —
  # only safe for test deployments. The /v1/* REST shim below is
  # authenticated (Authorization: Bearer <token> or body.auth = …).
  location /mcp {
    proxy_pass http://{{ nginx_upstream_host | default('127.0.0.1') }}:{{ upstream_mcp_port }};
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_http_version 1.1;
    proxy_set_header Connection "";
    proxy_buffering off;
    proxy_read_timeout 24h;
    proxy_send_timeout 24h;
  }

  # REST shim — friendly tenant bootstrap / city-setup endpoints for the
  # configurator + onboarding UI. Authentication is enforced inside the
  # MCP server (bearer token or body.auth credentials).
  location /v1/ {
    proxy_pass http://{{ nginx_upstream_host | default('127.0.0.1') }}:{{ upstream_mcp_port }};
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_set_header Authorization $http_authorization;
    proxy_http_version 1.1;
    proxy_read_timeout 600s;
    proxy_send_timeout 600s;
  }

{% endif %}
{% if enable_novu | default(false) %}
{% if build_novu_dashboard | default(false) %}
  # Novu dashboard (SPA) — REBASED image (backend/novu-dashboard/Dockerfile,
  # built when `build_novu_dashboard: true`). The dist is baked to base=/novu, so the
  # served HTML/JS reference /novu/assets, /novu/manifest.json, /novu/favicon-*
  # consistently. The files still live at the container ROOT, so the trailing
  # slash on proxy_pass strips the /novu prefix and hits them. One /novu/ block
  # therefore covers shell + assets + manifest + favicons + SPA fallback.
  #
  # Two residues still surface at the root and are handled below:
  #   - Novu's auth shim navigates to /auth/sign-in|sign-up|organization-list
  #     and ignores the router basename (can't be moved under /novu).
  #   - A few decorative logos/background are fetched at /images/* at runtime.
  location = /novu { return 302 /novu/; }
  location /novu/ {
    proxy_pass http://127.0.0.1:14000/;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_http_version 1.1;
  }

  # Novu's auth shim uses these three ROOT paths regardless of base. They do
  # NOT overlap Keycloak (which serves /auth/realms|admin|resources/*), so scope
  # exactly these to the dashboard and let everything else under /auth/ fall
  # through to the keycloak vhost block. `^~` stops regex-location evaluation;
  # being a longer prefix than a generic `/auth/`, these win for these paths.
  location ^~ /auth/sign-in           { proxy_pass http://127.0.0.1:14000; proxy_set_header Host $host; proxy_http_version 1.1; }
  location ^~ /auth/sign-up           { proxy_pass http://127.0.0.1:14000; proxy_set_header Host $host; proxy_http_version 1.1; }
  location ^~ /auth/organization-list { proxy_pass http://127.0.0.1:14000; proxy_set_header Host $host; proxy_http_version 1.1; }

  # Decorative dashboard logos/background, fetched unprefixed at runtime.
  location /images/ {
    proxy_pass http://127.0.0.1:14000/images/;
    proxy_set_header Host $host;
    proxy_http_version 1.1;
  }
{% else %}
  # Novu dashboard (SPA) — STOCK image. The official ghcr.io/novuhq/novu/dashboard
  # image is built with Vite `base=/`, despite VITE_BASE_PATH=/novu being set at
  # runtime (only API/WS hostnames are honored at runtime; the asset paths bake
  # at build time). That means the dashboard HTML references /assets/, /images/,
  # /manifest.json, /favicon-*, /auth/ — all UNPREFIXED. Below we proxy `/novu/`
  # plus those root-level paths.
  #
  # ⚠ WORKAROUND. Proper fix: set `build_novu_dashboard: true` to build the
  # subpath-rebased image (build/novu-dashboard/Dockerfile); then this branch is
  # replaced by the tidy one above. The stock branch ALSO hijacks the entire
  # `/auth/` prefix, so it is unsafe to combine with Keycloak on the same domain.
  location = /novu { return 302 /novu/; }
  location /novu/ {
    proxy_pass http://127.0.0.1:14000/novu/;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_http_version 1.1;
  }

  # ⚠ WORKAROUND for the upstream Vite base=/ bug. These root-level
  # paths are referenced by the dashboard HTML/JS and would 404
  # otherwise. Each block forwards to the dashboard container so the
  # SPA can boot and navigate without breakage.
  #
  # Conflict risk: if another surface on this domain ever serves at
  # /assets/, /images/, /static/ or /manifest.json, these blocks will
  # shadow it. Currently no other service does. The configurator at
  # /configurator/ uses its own /configurator/assets/ prefix; the
  # digit-ui uses /digit-ui/vendor/ — no collision.
  location /assets/ {
    proxy_pass http://127.0.0.1:14000/assets/;
    proxy_set_header Host $host;
    proxy_http_version 1.1;
  }
  location /static/ {
    proxy_pass http://127.0.0.1:14000/static/;
    proxy_set_header Host $host;
    proxy_http_version 1.1;
  }
  location /images/ {
    proxy_pass http://127.0.0.1:14000/images/;
    proxy_set_header Host $host;
    proxy_http_version 1.1;
  }
  # React Router internal routes — /auth/sign-in, /auth/sign-up, etc.
  # These need to serve the dashboard's index.html so client-side
  # routing takes over. The dashboard's http-server already does
  # SPA-style fallback for unknown paths.
  #
  # IMPORTANT ORDERING: this must be above any service-side `/auth`
  # route from Kong (e.g. the keycloak-route in kong.yml). Without
  # this proxy, hard-refreshes at /auth/* fall through to Kong's
  # /auth → keycloak upstream and 500 with a DNS resolve failure
  # when keycloak isn't deployed. ⚠ This shadows ALL of /auth/, so do
  # not enable the stock branch on a domain that also runs Keycloak —
  # use build_novu_dashboard: true (rebased branch) there instead.
  location /auth/ {
    proxy_pass http://127.0.0.1:14000;
    proxy_set_header Host $host;
    proxy_http_version 1.1;
  }

  # React Router deep links — /env/<envId>/activity-feed, /env/<envId>/workflows,
  # etc. Same class as /auth/ above: the dashboard is Vite base=/, so these are
  # root-absolute. A direct load / hard-refresh must serve the container's
  # index.html (the dashboard's http-server does SPA fallback) — otherwise it
  # falls through `location /` to Kong and 404s ("no Route matched with those
  # values"). Client-side nav from the dashboard home works either way; this is
  # only needed for deep-link / refresh.
  location /env/ {
    proxy_pass http://127.0.0.1:14000;
    proxy_set_header Host $host;
    proxy_http_version 1.1;
  }
  # Manifest + favicons (referenced unprefixed by the dashboard HTML).
  location = /manifest.json {
    proxy_pass http://127.0.0.1:14000/manifest.json;
    proxy_set_header Host $host;
  }
  location = /favicon-gradient.svg {
    proxy_pass http://127.0.0.1:14000/favicon-gradient.svg;
    proxy_set_header Host $host;
  }
  location = /favicon.ico {
    proxy_pass http://127.0.0.1:14000/favicon.ico;
    proxy_set_header Host $host;
  }
{% endif %}

  # Novu API (REST) — used by the dashboard SPA running in the
  # browser. Exposed on the host so VITE_API_HOSTNAME can resolve.
  location /novu-api/ {
    proxy_pass http://127.0.0.1:14002/;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_set_header Authorization $http_authorization;
    proxy_http_version 1.1;
  }

  # Novu websocket — used by the dashboard for live notification
  # status updates. Proxy upgrades the connection to WS.
  location /novu-ws/ {
    proxy_pass http://127.0.0.1:14003/;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_http_version 1.1;
    proxy_set_header Upgrade $http_upgrade;
    proxy_set_header Connection "upgrade";
    proxy_read_timeout 24h;
  }

  # novu-bridge: the read-only configurator proxy endpoints
  # (GET /novu-bridge/novu-adapter/v1/logs|integrations) are routed by Kong
  # (see local-setup/kong/kong.yml) and auth-gated INSIDE novu-bridge by
  # validating the DIGIT bearer token against egov-user /user/_details.
  # The POST diagnostic endpoints (_validate/_dry-run/_test-trigger) are
  # deliberately NOT routed publicly. Do NOT hand-wire an unauthenticated
  # location block for them.

{% endif %}
{% if enable_turbopass | default(false) %}
  # Turbopass search-api — OSM place-name autocomplete for the
  # configurator's Phase 2 boundary step
  # (GET /turbopass/search?q=<term>&limit=<n>). Proxies to the on-box
  # turbopass-search container (loopback only; started by the playbook's
  # "Turbopass" tasks behind the same enable_turbopass gate). The trailing
  # slash on proxy_pass strips the /turbopass prefix so the app sees
  # /search.
  location /turbopass/ {
    proxy_pass http://127.0.0.1:{{ turbopass_port | default(13301) }}/;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_http_version 1.1;
  }

{% endif %}
{% if enable_overpass | default(false) %}
  # Self-hosted Overpass — boundary-polygon fetch for the configurator's
  # Phase 2 OSM step (POST /overpass/api/interpreter). Proxies to the on-box
  # bomet-overpass container (loopback only; started by the playbook's
  # "Overpass" tasks behind the same enable_overpass gate). Trailing slash
  # strips the /overpass prefix so the app sees /api/interpreter.
  location /overpass/ {
    proxy_pass http://127.0.0.1:{{ overpass_port | default(12346) }}/;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_read_timeout 120s;
  }

{% endif %}
{% if digit_ui_mode == "static" %}
  # digit-ui in static mode: host nginx serves the build artifact from
  # /opt/digit-ui-esbuild/build/ directly. Built by the playbook
  # (`node esbuild.build.js`) — no inner Docker container, no esbuild
  # dev server. Faster, fewer moving parts, smaller blast radius.
  location = /digit-ui {
    return 302 /digit-ui/;
  }
  location /digit-ui/ {
    alias /opt/digit-ui-esbuild/build/;
    try_files $uri $uri/ /digit-ui/index.html;

    # gzip is SCOPED to this static-UI location ONLY (not server-level), so no
    # Kong-proxied API route is affected — this location serves files from disk
    # (the ~7-8 MB bundle + CSS), never proxies. ~4x smaller over the wire.
    # sub_filter runs before gzip, so the globalConfigs.js/theme HTML injection
    # is unaffected. text/html is gzip's built-in default (not re-listed).
    gzip on;
    gzip_vary on;
    gzip_min_length 1024;
    gzip_comp_level 5;
    gzip_types text/css application/javascript text/javascript application/json image/svg+xml;

    # Non-hashed bundle (fixed index.js): revalidate every load (cheap ETag
    # 304), so a redeploy is picked up immediately with no stale-cache risk.
    # Do NOT switch to immutable/long max-age until filenames are hashed.
    add_header Cache-Control "no-cache" always;
    sub_filter_once on;
    sub_filter_types text/html;
    # Inject globalConfigs.js + (optional) tenant theme tokens into <head>. Theme
    # tokens override --color-primary-1 etc. defined in vendored digit-ui-css /
    # overrides.css, so the SPA picks up tenant branding without touching the
    # built CSS. Driven by host_vars `theme_primary_color` (dark) +
    # `theme_primary_color_2` (light); omit either to keep DIGIT defaults.
    sub_filter '</head>' '{% if theme_primary_color is defined %}<style>:root{--color-primary-1:{{ theme_primary_color }};{% if theme_primary_color_2 is defined %}--color-primary-2:{{ theme_primary_color_2 }};--color-button-primary-bg-default:{{ theme_primary_color_2 }};--color-button-primary-border:{{ theme_primary_color_2 }};--color-button-secondary-text:{{ theme_primary_color_2 }};--color-button-secondary-border:{{ theme_primary_color_2 }};--color-input-border-focus:{{ theme_primary_color_2 }};--color-link-default:{{ theme_primary_color_2 }};{% endif %}--color-button-primary-bg-hover:{{ theme_primary_color }};--color-link-hover:{{ theme_primary_color }};{% if theme_sidebar_selected_bg is defined %}--color-sidebar-selected-bg:{{ theme_sidebar_selected_bg }};{% endif %}}</style>{% endif %}<script src="/digit-ui/globalConfigs.js"></script></head>';
  }
  # Per-tenant boot config — overrides whatever was baked into the bundle.
  location = /digit-ui/globalConfigs.js {
    alias {{ digit_dir }}/nginx/globalConfigs.js;
    default_type application/javascript;
    add_header Cache-Control "no-cache, must-revalidate" always;
  }

  # ----------------------------------------------------------------
  # egov-filestore presigned-URL rewrite (CCRS#555). Upstream filestore
  # signs URLs against `Host: minio:9000` and embeds the same internal
  # hostname into every URL it returns; browsers can't resolve that.
  # Fix at the edge:
  #   /file-store/ — public passthrough to host-bound minio. We re-set
  #     `Host: minio:9000` so the AWS4 signature (computed over Host
  #     + path + query at sign time) still verifies inside minio.
  #   /filestore/  — egov-filestore JSON API. sub_filter rewrites
  #     `http://minio:9000/` in response bodies to the public passthrough
  #     above. Accept-Encoding stripped so sub_filter sees uncompressed JSON.
  #     The replacement uses runtime $host (not the inventory `domain` var)
  #     so attachment URLs follow whatever hostname the client actually
  #     used — a box rendered with `domain: localhost` but served on a real
  #     domain otherwise hands browsers unresolvable localhost URLs (CCRS#753).
  #     Safe for the AWS4 signature: /file-store/ re-sets Host to minio:9000,
  #     so the public hostname never participates in signature validation.
  location /file-store/ {
    proxy_pass http://{{ nginx_upstream_host | default('127.0.0.1') }}:{{ upstream_minio_port | default(19000) }}/;
    proxy_set_header Host minio:9000;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_http_version 1.1;
    client_max_body_size 25M;
    proxy_buffering off;
  }

  location /filestore/ {
    proxy_pass http://{{ nginx_upstream_host | default('127.0.0.1') }}:{{ upstream_kong_port }};
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_set_header Accept-Encoding "";
    sub_filter_once off;
    sub_filter_types application/json;
    sub_filter 'http://minio:9000/' '{{ "https://" if (tls_enabled | default(true)) else "http://" }}$host/file-store/';
    client_max_body_size 25M;
    proxy_buffering off;
  }

{% if nginx_features.root_to_digit_ui | default(false) %}
  # Bare domain -> citizen app login. Lands users in the digit-ui SPA
  # instead of Kong's default response. Exact match (=), so the catch-all
  # below still proxies everything else to Kong.
  location = / { return 302 /digit-ui/citizen/login; }
{% endif %}

  # API calls go to Kong directly.
  location / {
    proxy_pass http://{{ nginx_upstream_host | default('127.0.0.1') }}:{{ upstream_kong_port }};
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_read_timeout 120s;
    proxy_buffering off;
  }
{% elif digit_ui_mode == "container" %}
  # digit-ui in CONTAINER mode: the digit-ui container serves the SPA on
  # :{{ upstream_esbuild_port }}. CRITICAL: only /digit-ui/* goes to that
  # container — ALL API (/user, /egov-*, /pgr-services, ...) MUST go to
  # Kong. The pre-fix template had NO `container` branch, so this fell
  # into the HMR `else` and sent /user/oauth/token to
  # :{{ upstream_esbuild_port }} (no API there) → 504 on every login.
  location = /digit-ui {
    return 302 /digit-ui/;
  }
  location /digit-ui/ {
    proxy_pass http://{{ nginx_upstream_host | default('127.0.0.1') }}:{{ upstream_esbuild_port }};
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_read_timeout 120s;
    proxy_buffering off;
  }
  # Per-tenant boot config (globalConfigs.js) + silent-check-sso.html are served
  # by the digit-ui CONTAINER from its /host-nginx directory mount (see
  # digit-ui.conf) and reach here via the /digit-ui/ proxy above. We do NOT
  # alias a host file at this layer: on OrbStack a single-file bind mount of
  # globalConfigs.js isn't reliably materialized, and an atomic re-render
  # changes its inode (breaking a pinned mount) — the dir mount avoids both.

  # egov-filestore presigned-URL rewrite (same as static mode).
  location /file-store/ {
    proxy_pass http://{{ nginx_upstream_host | default('127.0.0.1') }}:{{ upstream_minio_port | default(19000) }}/;
    proxy_set_header Host minio:9000;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_http_version 1.1;
    client_max_body_size 25M;
    proxy_buffering off;
  }
  location /filestore/ {
    proxy_pass http://{{ nginx_upstream_host | default('127.0.0.1') }}:{{ upstream_kong_port }};
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_set_header Accept-Encoding "";
    sub_filter_once off;
    sub_filter_types application/json;
    sub_filter 'http://minio:9000/' '{{ "https://" if (tls_enabled | default(true)) else "http://" }}$host/file-store/';
    client_max_body_size 25M;
    proxy_buffering off;
  }

  # Everything else (ALL API) → Kong. THE fix for the login 504.
  location / {
    proxy_pass http://{{ nginx_upstream_host | default('127.0.0.1') }}:{{ upstream_kong_port }};
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_read_timeout 120s;
    proxy_buffering off;
  }
{% else %}
  # digit-ui in HMR mode: esbuild dev server (tmux session) on :18080.
  # Serves both /digit-ui/* (the SPA) and proxies API calls to Kong.
  # Live reloads on file save in /opt/digit-ui-esbuild.
  location / {
    proxy_pass http://{{ nginx_upstream_host | default('127.0.0.1') }}:{{ upstream_esbuild_port }};
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_read_timeout 120s;
    proxy_buffering off;
  }
{% endif %}

{% if tls_enabled | default(true) %}
    # Certbot-managed TLS. Set `tls_enabled: false` in host_vars/<tenant>.yml
    # for boxes without a Let's Encrypt cert (e.g. iteration sandboxes).
    listen 443 ssl; # managed by Certbot
    ssl_certificate /etc/letsencrypt/live/{{ domain }}/fullchain.pem; # managed by Certbot
    ssl_certificate_key /etc/letsencrypt/live/{{ domain }}/privkey.pem; # managed by Certbot
    include /etc/letsencrypt/options-ssl-nginx.conf; # managed by Certbot
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem; # managed by Certbot
{% else %}
    # tls_enabled=false — listen on plain HTTP only (sandbox / no Let's Encrypt cert).
    listen 80;
{% endif %}

}
{% if tls_enabled | default(true) %}
server {
    # HTTP→HTTPS redirect (only meaningful when TLS is on).
    if ($host = {{ domain }}) {
        return 301 https://$host$request_uri;
    } # managed by Certbot


  listen 80;
  server_name {{ domain }};
    return 404; # managed by Certbot


}
{% endif %}
