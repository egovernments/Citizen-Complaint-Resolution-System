{
  "title": "DIGIT — Logs (Loki)",
  "uid": "digit-loki-logs",
  "schemaVersion": 39,
  "version": 1,
  "tags": ["digit", "logs", "loki"],
  "timezone": "browser",
  "time": { "from": "now-1h", "to": "now" },
  "refresh": "30s",
  "templating": {
    "list": [
      {
        "name": "service",
        "label": "Service",
        "type": "query",
        "datasource": { "type": "loki", "uid": "loki" },
        "query": { "label": "service_name", "refId": "LokiVariableQueryEditor-VariableQuery", "stream": "", "type": 1 },
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "allValue": ".+",
        "current": { "selected": true, "text": ["All"], "value": ["$__all"] },
        "sort": 1
      },
      {
        "name": "level",
        "label": "Level",
        "type": "custom",
        "query": ".+,ERROR,WARN,INFO,DEBUG",
        "current": { "selected": true, "text": ".+", "value": ".+" },
        "options": [
          { "selected": true, "text": ".+", "value": ".+" },
          { "selected": false, "text": "ERROR", "value": "ERROR" },
          { "selected": false, "text": "WARN", "value": "WARN" },
          { "selected": false, "text": "INFO", "value": "INFO" },
          { "selected": false, "text": "DEBUG", "value": "DEBUG" }
        ]
      },
      {
        "name": "q",
        "label": "Search regex",
        "type": "textbox",
        "query": ".+",
        "current": { "selected": true, "text": ".+", "value": ".+" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Log lines (current range)",
      "description": "Total log lines from selected services across the dashboard time range.",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["sum"], "fields": "", "values": false },
        "graphMode": "area",
        "colorMode": "value",
        "justifyMode": "center",
        "textMode": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum(count_over_time({service_name=~\"$service\"} |~ \"(?i)$level\" [$__range]))",
          "queryType": "instant"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Errors / Exceptions (current range)",
      "description": "Count of lines matching error|exception|outofmemory across selected services.",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["sum"], "fields": "", "values": false },
        "graphMode": "area",
        "colorMode": "background",
        "justifyMode": "center",
        "textMode": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum(count_over_time({service_name=~\"$service\"} |~ \"(?i)error|exception|outofmemory\" [$__range]))",
          "queryType": "instant"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Log volume by service (rate / sec)",
      "description": "Per-service log line rate using count_over_time with a 1m window.",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "logs",
          "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 10, "stacking": { "mode": "normal", "group": "A" } }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "max"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum by (service_name) (rate({service_name=~\"$service\"}[1m]))",
          "queryType": "range",
          "legendFormat": "{{service_name}}"
        }
      ]
    },
    {
      "id": 4,
      "type": "logs",
      "title": "Logs",
      "description": "Live log stream from selected services. Use the 'Search regex' variable for free-form filtering.",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 22, "w": 24, "x": 0, "y": 8 },
      "options": {
        "showTime": true,
        "showLabels": false,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "dedupStrategy": "none",
        "sortOrder": "Descending"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "{service_name=~\"$service\"} |~ \"(?i)$level\" |~ \"$q\"",
          "queryType": "range"
        }
      ]
    }
  ]
}
