# DIGIT Integration Tests — Environment Configuration
#
# Copy to .env and fill in values for your deployment.
# All values have sensible defaults for the Kenya (ke) deployment.

# Base URL of the DIGIT UI (no trailing slash)
BASE_URL=https://naipepea.digit.org

# Tenant IDs
DIGIT_TENANT=ke.nairobi         # City-level tenant (for PGR, HRMS, etc.)
ROOT_TENANT=ke                   # State/root tenant (for MDMS, auth)

# Admin credentials (employee with ADMIN role)
DIGIT_USERNAME=ADMIN
DIGIT_PASSWORD=eGov@123

# Citizen phone number prefix (first digit(s) that pass mobile validation)
# Kenya: 7 or 1 | India: 6-9 | Default: 7
CITIZEN_PHONE_PREFIX=7

# Fixed OTP value (mock OTP deployments use a fixed value)
FIXED_OTP=123456

# PGR service code to use for complaint creation tests
# Must exist in RAINMAKER-PGR.ServiceDefs AND match an employee's department
SERVICE_CODE=IllegalConstruction

# Boundary locality code for complaint address
# Must exist in boundary-service for the tenant
LOCALITY_CODE=NAIROBI_CITY_VIWANDANI

# ============================================================================
# 2026-05/06 validation suite — non-ADMIN persona usernames + bounds
# ============================================================================

# digit-ui employee login (PGR_LME / GRO). The bomet deployment seeds
# BOMET_LME / eGov@123; replace per-deployment.
EMPLOYEE_USER=BOMET_LME
EMPLOYEE_PASSWORD=eGov@123

# Ward-scoped CSR for the #496 jurisdiction-filter regression. The
# bomet deployment seeded BOMET_CSR_CHESOEN_1780282462 via
# /egov-hrms/employees/_create with a Ward jurisdiction. Replace per
# deployment + match the leaf-ward code below.
WARD_CSR_USER=BOMET_CSR_CHESOEN_1780282462
WARD_CSR_PASSWORD=eGov@123

# Leaf-ward boundary code the WARD_CSR_USER is scoped to.
WARD_CSR_BOUNDARY=BOMET_BOMET_CENTRAL_CHESOEN

# Sibling / cross-sub-county wards that MUST NOT appear in the CSR's
# boundary picker. Comma-separated.
FORBIDDEN_WARDS=BOMET_BOMET_CENTRAL_MUTARAKWA,BOMET_BOMET_CENTRAL_NADARAWETA,BOMET_BOMET_CENTRAL_SILIBWET_TOWNSHIP,BOMET_BOMET_CENTRAL_SINGORWET,BOMET_BOMET_EAST_KEMBU,BOMET_CHEPALUNGU_CHEBUNYO,BOMET_KONOIN_KIMULOT

# Display label of the deployment in the digit-ui login City combobox.
TENANT_LABEL=Bomet County

# Known PGR complaint at PENDINGATLME assigned to EMPLOYEE_USER.
# Used by the manual-Escalate spec to find a row to act on.
ASSIGNED_COMPLAINT_ID=PG-PGR-2026-04-13-000848

# Set to 1 ONLY on a deployment where STATE_LEVEL_TENANT_ID has been
# flipped post-deploy via `docker compose up -d --force-recreate`.
# Unblocks tests/lifecycle/enc-key-drift-622.spec.ts.
# PLAYWRIGHT_FORCE_RECREATE_FLIP=1
