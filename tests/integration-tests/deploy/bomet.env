# Bomet deploy config for the integration-tests suite + dashboards.
#
# Public config only — NO secrets. Basic-auth creds live in
# /etc/nginx/.htpasswd-tests on the box, never here.
#
# Usage (from a runner that can ssh to `bomet`):
#   set -a; source deploy/bomet.env; set +a
#   make test-and-publish
#
# Every value below overrides a default that points at naipepea, so the
# same branch deploys to any tenant by swapping this file.

# ── Suite target (read-mostly black-box client against the live API) ──────────
export BASE_URL=https://bometfeedbackhub.digit.org
export DIGIT_TENANT=ke            # bomet is single-level `ke`, NOT ke.nairobi
export ROOT_TENANT=ke
export TENANT_LABEL="Bomet County"

# Citizen complaint creation needs a real bomet locality + service code.
# `IllegalConstruction` (the naipepea default) does NOT exist on bomet.
export LOCALITY_CODE=BOMET_BOMET_CENTRAL_CHESOEN
export SERVICE_CODE=RudeBehavior

# Personas (BOMET_LME / BOMET_CSR_CHESOEN_… / ward boundaries) are already the
# defaults in tests/utils/env.ts, so they're omitted here on purpose.

# Configurator tenants-search test. NOTE: bomet is a single-tenant `ke`
# deployment — there is no city sub-tenant, and the configurator's mdms-v2
# tenant.tenants master holds only test-created ke.pwt*/ke.tgt* junk. So this
# test is environmentally N/A here (no real city tenant to search for); `ke`
# is the honest target even though the configurator list may not surface it.
export CITY_TENANT=ke

# pgr-postal-code spec logs in as a "city admin"; naipepea's default
# EMP-KE_NAIROBI-000089 doesn't exist on bomet → use a real bomet employee.
export CITY_ADMIN_USER=BOMET_LME
export CITY_ADMIN_PASS=eGov@123

# ── Publish target ────────────────────────────────────────────────────────────
export HOST_SSH=bomet
export HOST_DIR=/opt/integration-tests/dist          # vanilla dashboard + catalog.json + runs/
export BRANCH=feat/bomet-integration-deploy

# ── React-admin (v2) dashboard build base ─────────────────────────────────────
# Served at /integration-tests-v2/ on the bomet vhost.
export DASHBOARD_BASE=/integration-tests-v2/
export TESTS_PROXY_TARGET=https://bometfeedbackhub.digit.org
