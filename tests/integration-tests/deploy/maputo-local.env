# Local mz.maputo stack config for the integration-tests suite.
#
# Public config only — NO secrets (local dev passwords are the stock eGov@123).
#
# Usage:
#   set -a; source deploy/maputo-local.env; set +a
#   npx playwright test tests/citizen tests/employee
#
# Targets the local DIGIT stack at /opt/digit (deployed via
# local-setup/ansible/deploy.sh maputo), onboarded from
# local-testing/onboarding/*.xlsx. `deploy.sh` alone is NOT enough: it seeds no
# boundaries, no complaint types and no real employees — run the XLSX onboarding
# first or every data-coupled spec here will skip.

# Which capabilities this deployment SHOULD have. Discovery decides HOW to test;
# this decides whether a missing capability is a bug (fail) or N/A (skip).
export EXPECTATIONS_FILE=deploy/expectations/maputo-local.json

# ── Suite target ─────────────────────────────────────────────────────────────
export BASE_URL=http://localhost
export DIGIT_TENANT=mz.maputo         # city tenant; state root is `mz`
export ROOT_TENANT=mz
# The employee login's City combobox renders the LOCALIZED tenant name
# (TENANT_TENANTS_MZ_MAPUTO -> "Maputo"), not the XLSX display name: the tenant
# already existed from tenant_bootstrap, so the onboarding's tenant phase was a
# no-op and never applied "Município de Maputo".
export TENANT_LABEL="Maputo"
export CITY_TENANT=mz.maputo
export LOCAL_STACK=1                  # opt in to @local-only specs

# fixtures/auth.setup.ts walks the configurator login form and reads its own
# TENANT_CODE/ADMIN_USER vars (not DIGIT_TENANT/DIGIT_USERNAME). The configurator
# admin authenticates at the state root.
export TENANT_CODE=mz
export ADMIN_USER=ADMIN
export ADMIN_PASSWORD=eGov@123

# ── Citizen complaint creation ───────────────────────────────────────────────
# Onboarded catalogue is exactly reparo_buracos (obras_publicas) + colecta_lixo
# (ambiental); the pg-default Garbage/StreetLights nodes are deactivated at `mz`.
# Leaf locality: MAPUTO_ADMIN's levels are Município > Distrito Municipal >
# Bairro > Quarteirão, so a locality code is a Quarteirão.
export SERVICE_CODE=colecta_lixo
export LOCALITY_CODE=ribzwene_q5
export CITIZEN_PHONE_PREFIX=8         # MZ mobile rule is ^8[0-9]{8}$ (+258)
export PGR_ID_PREFIX=PG

# ── Personas ─────────────────────────────────────────────────────────────────
# EMP001 (Jane Doe) is the only onboarded employee and carries GRO + PGR_LME +
# EMPLOYEE, so it can drive both ASSIGN and RESOLVE. It lives at the CITY tenant
# and 400s if the OAuth call targets the root, hence EMPLOYEE_TENANT.
export EMPLOYEE_USER=EMP001
export EMPLOYEE_PASSWORD=eGov@123
export EMPLOYEE_TENANT=mz.maputo
export GRO_USER=EMP001
export GRO_PASSWORD=eGov@123
export CITY_ADMIN_USER=EMP001
export CITY_ADMIN_PASS=eGov@123

# ── Deployment-shaped assertions ─────────────────────────────────────────────
# MZ postal codes are 4 digits + optional 2-digit sector; mirrors
# host_vars/maputo.yml core_postal_configs.postalCodePattern.
export POSTAL_CODE_PATTERN='^[0-9]{4}(-[0-9]{2})?$'
export POSTAL_CODE_VALID=0101-03
export LOCALES=en_IN                  # pt_MZ needs a separate localization upload

# WARD_CSR_* / FORBIDDEN_WARDS are deliberately left at the suite's bomet-shaped
# defaults: that persona doesn't exist here, so boundary-jurisdiction-496 skips
# itself rather than asserting against another deployment's wards.
