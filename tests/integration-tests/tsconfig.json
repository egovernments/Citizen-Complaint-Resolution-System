{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "types": ["node"]
  },
  "include": [
    "auth.setup.ts",
    "specs/**/*.ts",
    "helpers/**/*.ts",
    "tests/**/*.ts",
    "playwright.config.ts"
  ]
}
