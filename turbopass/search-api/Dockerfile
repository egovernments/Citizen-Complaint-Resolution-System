# Build stage
FROM node:20-alpine AS build
WORKDIR /app
COPY package.json package-lock.json ./
RUN npm ci
COPY . .
RUN npm run build

# Runtime stage
FROM node:20-alpine
WORKDIR /app
ENV NODE_ENV=production
COPY package.json package-lock.json ./
RUN npm ci --omit=dev
COPY --from=build /app/dist ./dist
# Scraped OSM data is mounted at /data (see search.service.ts DATA_DIR resolution)
ENV DATA_DIR=/data
EXPOSE 3000
CMD ["node", "dist/main"]
