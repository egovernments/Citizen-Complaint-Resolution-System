# ==============================================================================
# AUTHENTICATION (optional — set here to avoid editing Cell 1 each time)
# Uses DIGIT_* prefix to avoid clashing with Linux system variables like USERNAME
# ==============================================================================
# DIGIT_BASE_URL=https://unified-dev.digit.org
# DIGIT_USERNAME=SUPERADMIN
# DIGIT_PASSWORD=your_password
# DIGIT_TENANT_ID=pg

# ==============================================================================
# SERVICE ENDPOINTS (Configurable)
# ==============================================================================
# Service endpoints appended to base_url
# Format: {base_url}{service_endpoint}
# Example: https://unified-dev.digit.org/mdms-v2

MDMS_V2_SERVICE=/mdms-v2
BOUNDARY_SERVICE=/boundary-service
BOUNDARY_MGMT_SERVICE=/boundary-management
LOCALIZATION_SERVICE=/localization
WORKFLOW_SERVICE=/egov-workflow-v2
FILESTORE_SERVICE=/filestore
HRMS_SERVICE=/egov-hrms
DATA_HANDLER_SERVICE=/default-data-handler
AUTH_SERVICE=/user



