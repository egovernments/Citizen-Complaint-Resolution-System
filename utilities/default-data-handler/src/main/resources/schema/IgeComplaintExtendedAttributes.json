{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "IgeComplaintExtendedAttributes",
  "title": "IGE Complaint Extended Attributes",
  "description": "Validates the flat extendedAttributes JSONB for IGE complaints. x-security lists the fields digit-config-service must encrypt/decrypt via egov-enc-service.",
  "type": "object",
  "required": ["caseRelatedTo", "instituteName"],
  "x-security": ["instituteName", "witnessName", "witnessAddress", "witnessNote"],
  "additionalProperties": false,
  "properties": {
    "isConfidential": { "type": "boolean", "default": false },
    "caseRelatedTo":  { "type": "string", "const": "IGE" },
    "schemaVersion":  { "type": "string" },
    "hierarchyLevel1": { "type": "string", "maxLength": 100 },
    "hierarchyLevel2": { "type": "string", "maxLength": 100 },
    "instituteName":  { "type": "string", "maxLength": 300 },
    "witnessName":    { "type": "string", "maxLength": 200 },
    "witnessAddress": { "type": "string", "maxLength": 1000 },
    "witnessNote":    { "type": "string", "maxLength": 1000 }
  }
}
