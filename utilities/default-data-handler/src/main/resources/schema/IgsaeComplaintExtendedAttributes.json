{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "IgsaeComplaintExtendedAttributes",
  "title": "IGSAE Complaint Extended Attributes",
  "description": "Validates the flat extendedAttributes JSONB for IGSAE complaints. x-security lists the fields digit-config-service must encrypt/decrypt via egov-enc-service.",
  "type": "object",
  "required": ["caseRelatedTo", "entityName", "dateOfFact", "entityAddress"],
  "x-security": ["dateOfFact", "entityName", "entityAddress", "witnessName", "witnessAddress", "witnessNote"],
  "additionalProperties": false,
  "properties": {
    "isConfidential": { "type": "boolean", "default": false },
    "caseRelatedTo":  { "type": "string", "const": "IGSAE" },
    "schemaVersion":  { "type": "string" },
    "hierarchyLevel1": { "type": "string", "maxLength": 100 },
    "hierarchyLevel2": { "type": "string", "maxLength": 100 },
    "dateOfFact":     { "type": "string", "format": "date" },
    "entityName":     { "type": "string", "maxLength": 300 },
    "entityAddress":  { "type": "string", "maxLength": 1000 },
    "witnessName":    { "type": "string", "maxLength": 200 },
    "witnessAddress": { "type": "string", "maxLength": 1000 },
    "witnessNote":    { "type": "string", "maxLength": 1000 }
  }
}
