[
  {
    "tenantId": "{tenantid}",
    "code": "RAINMAKER-PGR.LandingSection",
    "description": "One row per configurable public-landing section (config-driven landing, CCSD-2005). type selects the section component (v1 catalog: hero, navigation, types, steps, channels, privacy, news, institutions, cta, footer) — intentionally NOT enum-constrained here so new types can be added later without a schema recreation (MDMS schema _update is unsupported); the catalog is enforced by the runtime LandingRenderer type->component registry and the Configurator type picker. order sorts; enabled toggles; status gates DRAFT vs PUBLISHED (runtime renders PUBLISHED). Text is carried as PGR_LANDING_* localization keys (never inline translated text); media is a filestore id; items are cards/links/steps for the section. WhatsApp FAB and the utility bar are page-level toggles on LandingPageConfig, not section types.",
    "isActive": true,
    "definition": {
      "type": "object",
      "title": "LandingSection",
      "$schema": "http://json-schema.org/draft-07/schema#",
      "required": [
        "code",
        "type",
        "order",
        "enabled"
      ],
      "x-unique": [
        "code"
      ],
      "properties": {
        "code": {
          "type": "string"
        },
        "type": {
          "type": "string",
          "description": "Section component key. v1 catalog: hero | navigation | types | steps | channels | privacy | news | institutions | cta | footer. Not enum-constrained (schema _update is unsupported); enforced by the LandingRenderer registry + Configurator picker so new types are addable without recreating the schema."
        },
        "order": {
          "type": "number"
        },
        "enabled": {
          "type": "boolean"
        },
        "status": {
          "type": "string",
          "enum": [
            "DRAFT",
            "PUBLISHED"
          ]
        },
        "version": {
          "type": "number"
        },
        "roles": {
